# ──────────────────────────────────────────────────────────────────────────
# Rhodawk EmbodiedOS DevSecOps Engine — environment template
# Copy to `.env` and fill in. Only the items marked REQUIRED must be set.
# ──────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────
# 1. The PRIMARY brain. Get a key at:
#    https://cloud.digitalocean.com/gen-ai/agents  →  Inference  →  API Keys
DO_INFERENCE_API_KEY=

# 2. GitHub PAT with scopes: repo, security_events.
GITHUB_TOKEN=

# ── STRONGLY RECOMMENDED (FALLBACK lane + OR-only models) ────────────────
# Without this, the OR-only members of the squad (kimi-k2.5, claude-4.6-sonnet,
# minimax-m2.5) silently fall back to a DO model. With it, they activate.
OPENROUTER_API_KEY=

# ── OPTIONAL — repo to operate against (can also be set in the chat UI) ──
GITHUB_REPO=

# ── PROVIDER ENDPOINTS (defaults shown — only set if you self-host) ──────
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── THE MODEL SQUAD — override any role to swap the underlying model ─────
EXECUTION_MODEL=llama-3.3-70b-instruct
HERMES_MODEL=deepseek-r1-distill-llama-70b
RECON_MODEL=kimi-k2.5
TRIAGE_MODEL=qwen3-32b
FALLBACK_MODEL=claude-4.6-sonnet
FALLBACK_MODEL_ALT=minimax-m2.5

# Aider's default model (built from EXECUTION_MODEL when DO key is present).
# Leave unset to use the auto-derived default.
# RHODAWK_MODEL=openai/llama-3.3-70b-instruct
# RHODAWK_FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct

# Hermes routing flag: auto | openclaude_grpc | do | openrouter
HERMES_PROVIDER=auto

# ── OPTIONAL BOUNTY / INTEL DATA SOURCES (degrade silently if missing) ───
HACKERONE_API_KEY=
HACKERONE_USERNAME=
BUGCROWD_API_KEY=
NVD_API_KEY=
BRAVE_API_KEY=
SEMGREP_APP_TOKEN=
NUCLEI_API_KEY=
SHODAN_API_KEY=
URLSCAN_API_KEY=

# ── OPTIONAL RESIDENTIAL PROXY FOR CAMOFOX BROWSER ───────────────────────
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ── OPTIONAL SUBSYSTEM TOGGLES ───────────────────────────────────────────
NIGHT_HUNTER=0
MYTHOS_API=0
META_LEARNER_ENABLED=1
OPENCLAW=1
RHODAWK_HARVESTER_ENABLED=false

# ── HOST PORT MAPPING (only used by docker compose / install.sh) ─────────
# The container always binds 7860 internally; this is the host-side mapping.
HOST_PORT=7860

# ─────────────────────────────────────────────────────────────────────────
# RHODAWK ENHANCEMENT GAPS — infra-side environment variables.
# Aligned with RHODAWK_AUDIT_REPORT.md → Phase 1 (Actions 1–3).
# ─────────────────────────────────────────────────────────────────────────

# ── GAP 1: SAST (CodeQL + Semgrep + QRS) ─────────────────────────────────
CODEQL_BIN=/opt/codeql/codeql
SEMGREP_BIN=semgrep
CODEQL_DB_DIR=/data/codeql_dbs
SAST_TIMEOUT_SECONDS=600

# ── GAP 2: Coverage-Guided Fuzzing (AFL++ + Atheris) ─────────────────────
AFL_BIN=afl-fuzz
AFL_CC=afl-clang-fast
FUZZ_TIMEOUT_SECONDS=1800
FUZZ_CORPUS_DIR=/data/fuzz_corpus
FUZZ_FINDINGS_DIR=/data/fuzz_findings

# ── GAP 3: Deterministic Exploit Validator ───────────────────────────────
# Sandbox backend. Allowed values: docker | firejail | none
# `docker`   → run challenge in a hardened, network-egress-blocked container
# `firejail` → run challenge under firejail seccomp profile
# `none`     → in-process (development only — DO NOT use in production)
EXPLOIT_VALIDATOR_SANDBOX=docker
EXPLOIT_VALIDATOR_TIMEOUT=120
EXPLOIT_VALIDATOR_MAX_MEMORY_MB=256
EXPLOIT_VALIDATOR_NO_NETWORK=1

# ── GAP 6: Semantic Embedder (code-aware retrieval) ──────────────────────
# Primary model. Default is nomic-ai/nomic-embed-code (code-specialised).
# Falls back to nomic-ai/nomic-embed-text-v1.5, then BAAI/bge-small-en-v1.5.
RHODAWK_EMBED_MODEL=nomic-ai/nomic-embed-code
RHODAWK_EMBED_FALLBACK=nomic-ai/nomic-embed-text-v1.5
# Device selection. Leave blank for auto (cuda > mps > cpu).
RHODAWK_EMBED_DEVICE=
# On-disk model cache (mounted volume in the container).
RHODAWK_EMBED_CACHE_DIR=/data/embed_cache
# Encoder batch size + max input tokens (truncated, not split).
RHODAWK_EMBED_BATCH_SIZE=16
RHODAWK_EMBED_MAX_TOKENS=8192

# ── GAP 5: Threat Graph & MITRE ATT&CK ───────────────────────────────────
# Path to the enterprise STIX 2.1 bundle. The Dockerfile downloads this
# from the official MITRE/cti GitHub mirror at build time. If the file
# is missing, the mapper falls back to its built-in CWE→technique table.
MITRE_ATTCK_JSON=/opt/mitre/enterprise-attack.json
RHODAWK_THREAT_GRAPH_DB=/data/threat_graph.sqlite

# ── GAP 10: Compliance Reporting ─────────────────────────────────────────
# Output directory for generated JSON / Markdown / HTML reports.
RHODAWK_REPORT_DIR=/data/compliance_reports

# ─────────────────────────────────────────────────────────────────────────
# EmbodiedOS — Hermes Agent + OpenClaw fused into the Rhodawk stack.
# Section references map to the EmbodiedOS prompt (sections 4.1 – 4.7).
# Every variable below is OPTIONAL — the package degrades gracefully when
# any subsystem is unreachable.
# ─────────────────────────────────────────────────────────────────────────

# Master kill-switch for the whole `embodied` package (entrypoint.sh).
EMBODIED_OS_ENABLED=1

# ── EmbodiedOS MCP bridge (Section 4.2) ─────────────────────────────────
# The single MCP server that exposes every Rhodawk tool to BOTH Hermes
# Agent and OpenClaw.  HTTP transport is reachable inside the container.
EMBODIED_BRIDGE_HOST=127.0.0.1
EMBODIED_BRIDGE_PORT=8600
EMBODIED_BRIDGE_TRANSPORT=http
# Optional shared secret — clients must send "Authorization: Bearer <secret>".
EMBODIED_BRIDGE_SECRET=

# ── Nous Research Hermes Agent (Sections 3, 4.2, 4.3, 4.7) ──────────────
HERMES_AGENT_URL=http://127.0.0.1:8400
HERMES_AGENT_API_KEY=
HERMES_SKILLS_DIR=/root/.hermes/skills
HERMES_MEMORY_DIR=/root/.hermes/memory
HERMES_ENABLED=1

# ── OpenClaw multi-channel gateway (Sections 3, 4.1, 4.2) ───────────────
OPENCLAW_BASE_URL=http://127.0.0.1:8500
OPENCLAW_API_KEY=
OPENCLAW_SKILLS_DIR=/root/.openclaw/skills
OPENCLAW_CHROME_RELAY_URL=http://127.0.0.1:8501
OPENCLAW_ENABLED=1

# ── Skill Sync Engine (Section 4.5) ─────────────────────────────────────
# Where the unified, deduplicated agentskills.io catalogue is cached.
ARCHITECT_SKILLS_DIR=/app/architect/skills
EMBODIED_SKILL_CACHE=/tmp/embodied_skill_cache
EMBODIED_SKILL_SYNC_MIN=60
EMBODIED_SKILL_TOPK=12

# ── Unified Memory (Section 4.6) ────────────────────────────────────────
EMBODIED_SESSION_DIR=/tmp/embodied_session
EMBODIED_EPISODIC_DB=/data/embodied_episodic.sqlite
EMBODIED_PROCEDURAL_DIR=/data/embodied_procedural

# ── Continuous Learning Daemon (Section 4.7) ────────────────────────────
EMBODIED_LEARNING_ENABLED=1
EMBODIED_RESEARCH_MIN=30

# ── Side 2 submission gating (Section 4.4) ──────────────────────────────
# When 1, finished P1/P2 reports may be auto-submitted AFTER the first 50
# review-only cycles.  When 0 (default) every report is held for the
# operator to ``approve <finding-id>`` via Telegram / Discord / Slack.
EMBODIED_AUTOSUBMIT=0

# ── ACTS scoring threshold (Section G0DM0D3) ─────────────────────────────────
# Findings with ACTS < this threshold go to episodic memory only (not surfaced).
ACTS_SURFACE_THRESHOLD=72.0

# ── AutoTune EMA (model_router.py) ──────────────────────────────────────────
# α for exponential moving average of per-model ACTS scores.
# 0.10 = conservative (slow adaptation), 0.30 = aggressive (fast adaptation).
AUTOTUNE_EMA_ALPHA=0.15
# Minimum scored samples before a model is eligible for promotion.
AUTOTUNE_EMA_MIN_SAMPLES=5

# ── Claude Context MCP (@zilliz/claude-context-mcp) ─────────────────────────
# Milvus vector store credentials for semantic search over indexed repos.
MILVUS_TOKEN=
MILVUS_ADDRESS=https://in03-xxxx.serverless.gcp-us-west1.cloud.zilliz.com
# Collection name used for code indexing.
CLAUDE_CONTEXT_COLLECTION=rhodawk_context

# ── GEPA skill evolution ─────────────────────────────────────────────────────
# When 1, GEPA runs weekly and opens GitHub PRs (requires GITHUB_TOKEN).
GEPA_ENABLED=1
# When 1, DGM runs monthly and opens GitHub PRs (requires GITHUB_TOKEN).
DGM_ENABLED=1

# ── Legacy UI ────────────────────────────────────────────────────────────────
# Set to 1 to re-enable the legacy Gradio UI alongside the Telegram interface.
EMBODIED_LEGACY_UI=0
