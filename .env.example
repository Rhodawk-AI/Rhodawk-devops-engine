# ──────────────────────────────────────────────────────────────────────────
# Rhodawk EmbodiedOS DevSecOps Engine — environment template
# Copy to `.env` and fill in. Only the items marked REQUIRED must be set.
# ──────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────
# 1. The PRIMARY brain. Get a key at:
#    https://cloud.digitalocean.com/gen-ai/agents  →  Inference  →  API Keys
DO_INFERENCE_API_KEY=

# 2. GitHub PAT with scopes: repo, security_events.
GITHUB_TOKEN=

# ── STRONGLY RECOMMENDED (FALLBACK lane + OR-only models) ────────────────
# Without this, the OR-only members of the squad (kimi-k2.5, claude-4.6-sonnet,
# minimax-m2.5) silently fall back to a DO model. With it, they activate.
OPENROUTER_API_KEY=

# ── OPTIONAL — repo to operate against (can also be set in the chat UI) ──
GITHUB_REPO=

# ── PROVIDER ENDPOINTS (defaults shown — only set if you self-host) ──────
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── THE MODEL SQUAD — override any role to swap the underlying model ─────
EXECUTION_MODEL=llama-3.3-70b-instruct
HERMES_MODEL=deepseek-r1-distill-llama-70b
RECON_MODEL=kimi-k2.5
TRIAGE_MODEL=qwen3-32b
FALLBACK_MODEL=claude-4.6-sonnet
FALLBACK_MODEL_ALT=minimax-m2.5

# Aider's default model (built from EXECUTION_MODEL when DO key is present).
# Leave unset to use the auto-derived default.
# RHODAWK_MODEL=openai/llama-3.3-70b-instruct
# RHODAWK_FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct

# Hermes routing flag: auto | openclaude_grpc | do | openrouter
HERMES_PROVIDER=auto

# ── OPTIONAL BOUNTY / INTEL DATA SOURCES (degrade silently if missing) ───
HACKERONE_API_KEY=
HACKERONE_USERNAME=
BUGCROWD_API_KEY=
NVD_API_KEY=
BRAVE_API_KEY=
SEMGREP_APP_TOKEN=
NUCLEI_API_KEY=
SHODAN_API_KEY=
URLSCAN_API_KEY=

# ── OPTIONAL RESIDENTIAL PROXY FOR CAMOFOX BROWSER ───────────────────────
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ── OPTIONAL SUBSYSTEM TOGGLES ───────────────────────────────────────────
NIGHT_HUNTER=0
MYTHOS_API=0
META_LEARNER_ENABLED=1
OPENCLAW=1
RHODAWK_HARVESTER_ENABLED=false

# ── HOST PORT MAPPING (only used by docker compose / install.sh) ─────────
# The container always binds 7860 internally; this is the host-side mapping.
HOST_PORT=7860
